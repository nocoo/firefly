# Firefly Environment Variables
# Copy this file to .env and fill in the values

# ─────────────────────────────────────────────────────
# Cloudflare
# ─────────────────────────────────────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
CF_D1_DATABASE_ID=your_production_d1_database_id

# ─────────────────────────────────────────────────────
# Worker (D1 Proxy)
# ─────────────────────────────────────────────────────
WORKER_URL=https://your-worker.workers.dev
WORKER_SECRET=your_worker_secret

# ─────────────────────────────────────────────────────
# Auth.js (NextAuth)
# ─────────────────────────────────────────────────────
AUTH_SECRET=generate_a_random_32_char_string
AUTH_URL=http://localhost:7028
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
AUTH_ALLOWED_EMAILS=your_email@example.com

# ─────────────────────────────────────────────────────
# R2 (Cloudflare Object Storage)
# ─────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your-r2-public-domain.com
R2_KEY_PREFIX=optional/path/prefix/

# ─────────────────────────────────────────────────────
# Site (Optional)
# ─────────────────────────────────────────────────────
ALLOWED_DEV_ORIGINS=localhost
