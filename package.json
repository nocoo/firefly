{
  "name": "firefly",
  "version": "2.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -p 7028",
    "build": "tsc --noEmit && next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:worker": "cd worker && bun run test",
    "test:worker:coverage": "cd worker && bun run test:coverage",
    "typecheck": "tsc --noEmit && cd worker && tsc --noEmit",
    "lint": "bun run typecheck && biome check --no-errors-on-unmatched --error-on-warnings --max-diagnostics=500 . && bun run gate:dynamic-delete && bun run gate:ts-expect-error && bun run gate:test-skip",
    "lint:fix": "biome check --write --no-errors-on-unmatched --error-on-warnings --max-diagnostics=500 .",
    "gate:dynamic-delete": "bun run scripts/check-dynamic-delete.ts",
    "gate:ts-expect-error": "bun run scripts/check-ts-expect-error.ts",
    "gate:test-skip": "bun run scripts/check-test-skip.ts",
    "security": "bun scripts/run-security.ts",
    "test:e2e": "bun scripts/run-e2e.ts",
    "test:e2e:api": "bun scripts/run-e2e.ts --api-only",
    "test:e2e:browser": "bun scripts/run-e2e.ts --browser-only",
    "test:e2e:bdd": "bun run test:e2e:browser",
    "migrate": "bun scripts/migrations/migrate.ts up",
    "migrate:status": "bun scripts/migrations/migrate.ts status",
    "migrate:local": "bun scripts/migrations/migrate.ts up --target local",
    "prepare": "husky",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "4.1.10",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "17.1.0",
    "oxc-parser": "0.141.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1092.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nocoo/next-ai": "^0.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.20",
    "@radix-ui/react-avatar": "^1.2.3",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "ai": "7.0.34",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.31",
    "lucide-react": "1.25.0",
    "marked": "18.0.7",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "recharts": "^3.10.0",
    "server-only": "^0.0.1",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@babel/core": ">=7.29.6",
    "picomatch": ">=4.0.4",
    "brace-expansion": ">=5.0.6",
    "ws": ">=8.20.1",
    "path-to-regexp": ">=8.4.0",
    "hono": ">=4.12.31",
    "@hono/node-server": ">=1.19.13",
    "fast-uri": ">=3.1.2",
    "fast-xml-builder": ">=1.1.7",
    "fast-xml-parser": ">=5.7.0",
    "postcss": ">=8.5.10",
    "ip-address": ">=10.1.1",
    "qs": ">=6.15.2",
    "vite": ">=8.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts,js,jsx,mjs,cjs,json}": [
      "biome check --no-errors-on-unmatched --error-on-warnings --max-diagnostics=500 --staged"
    ]
  }
}
