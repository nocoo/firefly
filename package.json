{
  "name": "firefly",
  "version": "2.5.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -p 7028",
    "build": "bun scripts/build-cache-handler.ts && next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "security": "bun scripts/run-security.ts",
    "test:e2e": "bun scripts/run-e2e.ts",
    "test:e2e:api": "bun scripts/run-e2e.ts --api-only",
    "test:e2e:browser": "bun scripts/run-e2e.ts --browser-only",
    "migrate": "bun scripts/migrations/migrate.ts up",
    "migrate:status": "bun scripts/migrations/migrate.ts status",
    "migrate:test": "bun scripts/migrations/migrate.ts up --target test",
    "migrate:local": "bun scripts/migrations/migrate.ts up --target local",
    "prepare": "husky",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/openai": "^3.0.36",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "^6.0.104",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.12",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.5",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "picomatch": ">=4.0.4",
    "brace-expansion": ">=5.0.5",
    "path-to-regexp": ">=8.4.0",
    "hono": ">=4.12.12",
    "@hono/node-server": ">=1.19.13"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  }
}
