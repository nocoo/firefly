{
  "name": "firefly",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -p 7043",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "security": "bun scripts/run-security.ts",
    "test:e2e": "bun scripts/run-e2e.ts",
    "test:e2e:api": "bun scripts/run-e2e.ts --api-only",
    "test:e2e:browser": "bun scripts/run-e2e.ts --browser-only",
    "migrate": "bun scripts/migrations/migrate.ts up",
    "migrate:status": "bun scripts/migrations/migrate.ts status",
    "migrate:test": "bun scripts/migrations/migrate.ts up --target test",
    "migrate:local": "bun scripts/migrations/migrate.ts up --target local",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.49",
    "@ai-sdk/openai": "^3.0.36",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "^6.0.104",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.5",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "ulid": "^3.0.2"
  }
}
