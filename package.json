{
  "name": "firefly",
  "version": "2.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack -p 7028",
    "build": "next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:worker": "cd worker && bun run test",
    "test:worker:coverage": "cd worker && bun run test:coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "security": "bun scripts/run-security.ts",
    "test:e2e": "bun scripts/run-e2e.ts",
    "test:e2e:api": "bun scripts/run-e2e.ts --api-only",
    "test:e2e:browser": "bun scripts/run-e2e.ts --browser-only",
    "migrate": "bun scripts/migrations/migrate.ts up",
    "migrate:status": "bun scripts/migrations/migrate.ts status",
    "migrate:local": "bun scripts/migrations/migrate.ts up --target local",
    "prepare": "husky",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "17.0.7",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nocoo/next-ai": "^0.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-avatar": "^1.1.12",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "ai": "^6.0.199",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.25",
    "lucide-react": "1.17.0",
    "marked": "18.0.5",
    "next": "16.2.8",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "picomatch": ">=4.0.4",
    "brace-expansion": ">=5.0.6",
    "ws": ">=8.20.1",
    "path-to-regexp": ">=8.4.0",
    "hono": ">=4.12.21",
    "@hono/node-server": ">=1.19.13",
    "fast-uri": ">=3.1.2",
    "fast-xml-builder": ">=1.1.7",
    "fast-xml-parser": ">=5.7.0",
    "postcss": ">=8.5.10",
    "ip-address": ">=10.1.1",
    "qs": ">=6.15.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ]
  }
}
