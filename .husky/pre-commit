#!/usr/bin/env sh

# === Quality Gate: pre-commit ===
# G0 lockfile + G1 Static Analysis (typecheck + Biome + custom gates) + L1 unit tests
#
# Ordering matters: lint-staged may stash/restore the working tree, so it must
# NOT run in parallel with vitest/tsc (they would see mixed file versions).
# Sequence: G0 ‚Üí G1b lint-staged (serial) ‚Üí G1a typecheck ‚à• L1 tests ‚Üí G1c gates.

STAGED_FILES=$(git diff --cached --name-only)
PKG_CHANGES=$(echo "$STAGED_FILES" | grep -E '(^|/)package\.json$|(^|/)bun\.lock$' || true)

if [ -n "$PKG_CHANGES" ]; then
  bun install --frozen-lockfile 2>&1
  LOCK_EXIT=$?
  if [ $LOCK_EXIT -ne 0 ]; then
    echo "‚ùå pre-commit FAILED: Lockfile out of sync. Run 'bun install' and commit bun.lock."
    exit 1
  fi
fi

# Detect code / config changes. Docs-only commits skip heavy gates.
# Keep this superset in sync with lint-staged globs in package.json.
CODE_CHANGES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|mts|cts|js|jsx|mjs|cjs|json)$' || true)
# package.json / lockfile affect types (deps, peer ranges) ‚Äî always typecheck them.
TSC_AFFECTING=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|mts|cts)$|tsconfig.*\.json$|(^|/)package\.json$|(^|/)bun\.lock$' || true)
TS_STAGED=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|mts|cts)$' || true)
BIOME_STAGED=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx|mts|cts|js|jsx|mjs|cjs|json)$' || true)

if [ -z "$CODE_CHANGES" ]; then
  echo "‚è≠Ô∏è  pre-commit: no code changes staged ‚Äî skipping L1/G1 gates"
  exit 0
fi

# G1b first and alone ‚Äî lint-staged may stash partial worktree state.
if [ -n "$BIOME_STAGED" ]; then
  echo "‚ñ∏ G1b: Biome (lint-staged)"
  bunx lint-staged 2>&1
  LINT_EXIT=$?
  if [ "$LINT_EXIT" -ne 0 ]; then
    echo "‚ùå pre-commit FAILED: Biome errors in staged files."
    exit 1
  fi
else
  LINT_EXIT=0
fi

TMP_DIR=$(mktemp -d)
TEST_EXIT_FILE="$TMP_DIR/test_exit"
TSC_EXIT_FILE="$TMP_DIR/tsc_exit"

(
  bun run test 2>&1
  echo $? > "$TEST_EXIT_FILE"
) &
TEST_PID=$!

if [ -n "$TSC_AFFECTING" ]; then
  (
    bun run typecheck 2>&1
    echo $? > "$TSC_EXIT_FILE"
  ) &
  TSC_PID=$!
else
  echo 0 > "$TSC_EXIT_FILE"
  TSC_PID=""
fi

wait $TEST_PID
[ -n "$TSC_PID" ] && wait $TSC_PID

TEST_EXIT=$(cat "$TEST_EXIT_FILE")
TSC_EXIT=$(cat "$TSC_EXIT_FILE")
rm -rf "$TMP_DIR"

if [ "$TEST_EXIT" -ne 0 ]; then
  echo "‚ùå pre-commit FAILED: Unit tests failed."
  exit 1
fi

if [ "$TSC_EXIT" -ne 0 ]; then
  echo "‚ùå pre-commit FAILED: TypeScript type check errors."
  exit 1
fi

# G1c: custom gates against INDEX snapshot (not working tree)
if [ -n "$TS_STAGED" ]; then
  GATE_ROOT=$(mktemp -d -t firefly-precommit-gate.XXXXXXXX)
  MKTEMP_EXIT=$?
  if [ "$MKTEMP_EXIT" -ne 0 ] || [ -z "$GATE_ROOT" ] || [ ! -d "$GATE_ROOT" ]; then
    echo "‚ùå pre-commit FAILED: could not create temp dir for gate index snapshot."
    exit 1
  fi
  trap 'rm -rf "$GATE_ROOT"' EXIT INT TERM
  git checkout-index --prefix="$GATE_ROOT/" -a
  CHECKOUT_EXIT=$?
  if [ "$CHECKOUT_EXIT" -ne 0 ]; then
    echo "‚ùå pre-commit FAILED: git checkout-index for gate snapshot (exit=$CHECKOUT_EXIT)."
    exit 1
  fi

  FIREFLY_GATE_ROOT="$GATE_ROOT" bun run gate:dynamic-delete
  if [ $? -ne 0 ]; then
    echo "‚ùå pre-commit FAILED: dynamic delete gate."
    exit 1
  fi
  FIREFLY_GATE_ROOT="$GATE_ROOT" bun run gate:ts-expect-error
  if [ $? -ne 0 ]; then
    echo "‚ùå pre-commit FAILED: @ts-expect-error gate."
    exit 1
  fi
  FIREFLY_GATE_ROOT="$GATE_ROOT" bun run gate:test-skip
  if [ $? -ne 0 ]; then
    echo "‚ùå pre-commit FAILED: permanent test.skip/.only gate."
    exit 1
  fi
fi

echo "‚úÖ pre-commit passed: G0 Lockfile + L1 Unit + G1 Static Analysis (tsc + Biome + gates)"
